rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shuls are public to read (anonymous searchers); writes only via Admin SDK (seed/admin).
    match /shuls/{id} {
      allow read: if true;
      allow write: if false;
    }

    // Anyone can submit an add/edit/dispute (goes to the moderation queue). No public read/edit.
    match /submissions/{id} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.type in ['new', 'edit', 'dispute'];
      allow read, update, delete: if false;
    }

    // Everything else (searches analytics, admins, submission moderation) is Admin-SDK only.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
